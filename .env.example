APP_NAME="Vende Mas API"
APP_ENV=production
APP_KEY=base64:aaAQK+AWDM7+1q4qwfd+cXzA/JJtoXDbXiv4EV6MV0k=
APP_DEBUG=false
APP_URL=http://vende-mas.com.co

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
LOG_DB_REQUESTS=true

DB_CONNECTION=pgsql
DATABASE_URL=
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=vende_mas
DB_USERNAME=vende_mas
DB_PASSWORD=change-this-database-password
DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SANCTUM_STATEFUL_DOMAINS=
CORS_ALLOWED_ORIGINS=
#CORS_ALLOWED_ORIGINS=*

DOCS_AUTH_ENABLED=true
DOCS_USERNAME=
DOCS_PASSWORD=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
DOCUMENTS_DISK=documents
DOCUMENTS_ROOT=storage/app/documents
QUEUE_CONNECTION=redis

API_FORCE_INDEX_PAGINATION=true
API_DEFAULT_PER_PAGE=25
API_MAX_PER_PAGE=100
API_RATE_LIMIT_PER_MINUTE=240
API_GUEST_RATE_LIMIT_PER_MINUTE=60

CACHE_STORE=redis
DASHBOARD_CACHE_STORE=redis
SUPERADMIN_NAME=
SUPERADMIN_EMAIL=
# Obligatorio para crear superadmin. Minimo 12 caracteres.
SUPERADMIN_PASSWORD=
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1



MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Brevo SMTP gratuito para probar correos reales:
# 1. Crea/activa SMTP en Brevo.
# 2. Usa el login SMTP como BREVO_MAIL_USERNAME.
# 3. Usa la SMTP key como BREVO_MAIL_PASSWORD.
# 4. MAIL_FROM_ADDRESS debe ser un remitente verificado en Brevo.
# MAIL_MAILER=brevo
BREVO_MAIL_SCHEME=smtp
BREVO_MAIL_HOST=smtp-relay.brevo.com
BREVO_MAIL_PORT=587
BREVO_MAIL_USERNAME=
BREVO_MAIL_PASSWORD=

# Alias soportados para proveedores que entregan variables como SMTP_* / FROM_*.
# Si usas estos nombres, config/mail.php tambien los toma como fallback.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
FROM_NAME=



VITE_APP_NAME="${APP_NAME}"
